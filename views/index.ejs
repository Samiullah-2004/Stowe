<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login / Register - Scatch</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0a0a0a] min-h-screen flex items-center justify-center p-4 font-sans text-white">

    <div class="w-full max-w-5xl bg-[#111111] rounded-2xl shadow-2xl shadow-black overflow-hidden grid md:grid-cols-2 border border-white/5">

        <div class="hidden md:flex flex-col justify-between p-12 relative overflow-hidden">
            <div class="absolute -top-20 -left-20 w-72 h-72 bg-[#b4ff39]/10 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-[#b4ff39]/5 rounded-full blur-3xl"></div>

            <div class="relative z-10">
                <h2 class="text-4xl font-extrabold tracking-tight">
                    Stowe<span class="text-[#b4ff39]">.</span>
                </h2>
                <p class="mt-3 text-sm text-gray-400 max-w-xs">
                    Your premium custom shopping ecosystem — built for speed and control.
                </p>
            </div>

            <div class="relative z-10 space-y-5">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-[#b4ff39]/10 border border-[#b4ff39]/20 flex items-center justify-center text-[#b4ff39] text-sm font-bold">✓</div>
                    <p class="text-sm text-gray-300">Manage your shop layout with ease</p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-[#b4ff39]/10 border border-[#b4ff39]/20 flex items-center justify-center text-[#b4ff39] text-sm font-bold">✓</div>
                    <p class="text-sm text-gray-300">Secure account & session management</p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-[#b4ff39]/10 border border-[#b4ff39]/20 flex items-center justify-center text-[#b4ff39] text-sm font-bold">✓</div>
                    <p class="text-sm text-gray-300">Fast, modern, and reliable</p>
                </div>
            </div>

            <p class="relative z-10 text-xs text-gray-500">&copy; 2026 Stowe. All rights reserved.</p>
        </div>

        <div class="p-8 sm:p-12 flex flex-col justify-center bg-[#0a0a0a] md:bg-transparent">

            <div class="md:hidden text-center mb-8">
                <h2 class="text-3xl font-extrabold tracking-tight">Stowe<span class="text-[#b4ff39]">.</span></h2>
                <p class="text-xs text-gray-400 mt-1">Your premium custom shopping ecosystem</p>
            </div>

            <div class="mb-10">
                <h3 class="text-xl font-bold text-white">Create your account</h3>
                <p class="text-sm text-gray-400 mt-1 mb-6">Join us today, it only takes a minute.</p>

             

                <form action="/users/register" method="post" class="space-y-4">
                    <input type="text" placeholder="Full Name" name="fullname" required
                        class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-[#b4ff39] focus:border-[#b4ff39] outline-none transition-all">
                    <input type="email" placeholder="Email Address" name="email" required
                        class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-[#b4ff39] focus:border-[#b4ff39] outline-none transition-all">
                    <input type="password" placeholder="Password" name="password" required
                        class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-[#b4ff39] focus:border-[#b4ff39] outline-none transition-all">

                    <button type="submit"
                        class="w-full bg-[#b4ff39] hover:bg-[#a3eb2f] text-black font-semibold py-2.5 rounded-lg text-sm transition-colors">
                        Create Account
                    </button>
                </form>
            </div>

            <div class="relative mb-10">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-white/10"></div>
                </div>
                <div class="relative flex justify-center text-xs">
                    <span class="bg-[#0a0a0a] md:bg-[#111111] px-3 text-gray-500 uppercase tracking-wider">Existing user</span>
                </div>
            </div>

            <div>
                <h3 class="text-xl font-bold text-white">Welcome back</h3>
                <p class="text-sm text-gray-400 mt-1 mb-6">Log in to access your dashboard.</p>

              

                <% if (locals.success && success.length > 0) { %>
                    <div class="bg-[#b4ff39]/10 border border-[#b4ff39]/20 text-[#b4ff39] text-xs rounded-lg p-3 mb-4 flex items-center gap-2">
                        <span>✓</span> <p><%= success %></p>
                    </div>
                <% } %>

                <form action="/users/login" method="post" class="space-y-4">
                    <input type="email" placeholder="Email Address" name="email" required
                        class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-white/30 focus:border-white/30 outline-none transition-all">
                    <input type="password" placeholder="Password" name="password" required
                        class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-white/30 focus:border-white/30 outline-none transition-all">

                    <button type="submit"
                        class="w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors">
                        Login
                    </button>
                </form>
            </div>

        </div>
    </div>

</body>

</html>
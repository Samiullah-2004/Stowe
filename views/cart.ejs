<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart — Scatch</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    
</head>
<body class="bg-[#0a0a0a] text-gray-200 antialiased">
<%- include('partials/navbar') %>
    <div class="w-full min-h-[calc(100vh-4rem)] flex flex-col md:flex-row items-start px-6 lg:px-20 py-12 gap-10">
        
        <div class="w-full md:w-[65%] space-y-6">
            <h2 class="text-2xl font-bold tracking-tight text-white mb-4">Shopping Cart (<%= products.length %> items)</h2>
            
<% 
    // 1. Group the products and count their quantities
    let uniqueProducts = [];
    let itemCounts = {};

    products.forEach(function(product) {
        let id = product._id.toString();
        if (!itemCounts[id]) {
            itemCounts[id] = 0;
            uniqueProducts.push(product);
        }
        itemCounts[id]++;
    });

    // 2. Initialize pricing counters
    let totalMRP = 0; 
    let totalDiscount = 0; 
    let platformFee = products.length > 0 ? 20 : 0; 
%>

<% uniqueProducts.forEach(function(product) { 
    let id = product._id.toString();
    let qty = itemCounts[id]; // Get the dynamic quantity

    // Calculate pricing multiplied by the quantity
    let basePrice = Number(product.price) * qty;
    let itemDiscount = Number(product.discount || 0) * qty;
    let itemMRP = basePrice + itemDiscount;

    totalMRP += itemMRP;
    totalDiscount += itemDiscount;
%>
    <div class="w-full rounded-2xl overflow-hidden border border-white/5 shadow-sm flex flex-col sm:flex-row justify-between bg-[#111111] hover:border-[#b4ff39]/20 transition"
         style="--cart-bg: <%= product.bgcolor || '#1a1a1a' %>; --cart-panel: <%= product.panelcolor || '#111111' %>; --cart-text: <%= product.textcolor || '#e5e7eb' %>;">
        
        <div class="w-full sm:w-48 h-44 flex items-center justify-center p-4 bg-[var(--cart-bg)] shrink-0">
            <img class="h-full object-contain" 
                 src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" 
                 alt="<%= product.name %>">
        </div>

        <div class="flex-1 flex flex-col justify-between px-6 py-5 bg-[var(--cart-panel)] text-[var(--cart-text)]">
            <div class="flex justify-between items-start">
                <div>
                    <h3 class="text-lg font-bold tracking-tight"><%= product.name %></h3>
                </div>
                <a href="/cart/remove/<%= product._id %>" class="opacity-50 hover:opacity-100 hover:text-red-500 transition" title="Remove item entirely">
                    <i class="ri-delete-bin-6-line text-lg"></i>
                </a>
            </div>

            <div class="flex items-center justify-between mt-6 pt-4 border-t border-current/10">



                <div class="flex items-center gap-2">
                  <button onclick="updateCart('<%= product._id %>', 'subtract')" 
        class="w-7 h-7 bg-white/5 text-current flex rounded-full items-center justify-center border border-current/10 hover:bg-[#b4ff39]/10 hover:border-[#b4ff39]/30 hover:text-[#b4ff39] active:scale-95 transition">
    <i class="ri-subtract-line text-sm"></i>
</button>
                    
                    <div class="px-3 py-0.5 rounded-lg bg-white/5 font-semibold text-sm border border-current/10">
                        <%= qty.toString().padStart(2, '0') %>
                    </div>
                    
                    <button onclick="updateCart('<%= product._id %>', 'add')" 
        class="w-7 h-7 bg-white/5 text-current flex rounded-full items-center justify-center border border-current/10 hover:bg-[#b4ff39]/10 hover:border-[#b4ff39]/30 hover:text-[#b4ff39] active:scale-95 transition">
    <i class="ri-add-line text-sm"></i>
</button>
                </div>




                <div class="text-right">
                    <h4 class="text-xs opacity-50">Net Total</h4>
                    <h2 class="text-base font-bold">Rs. <%= (basePrice).toLocaleString() %></h2>
                </div>
            </div>
        </div>
    </div>
<% }) %>

            <% if (products.length === 0) { %>
                <div class="w-full text-center py-16 bg-[#111111] border border-white/5 rounded-3xl space-y-4">
                    <div class="w-14 h-14 bg-[#1a1a1a] border border-white/10 rounded-2xl flex items-center justify-center mx-auto text-gray-500">
                        <i class="ri-shopping-bag-line text-3xl"></i>
                    </div>
                    <div class="space-y-1">
                        <h3 class="text-lg font-bold text-white">Your cart is empty</h3>
                        <p class="text-gray-500 text-sm max-w-xs mx-auto">Looks like you haven't added any products to your cart yet.</p>
                    </div>
                    <a href="/products" class="inline-flex items-center justify-center px-5 py-2.5 bg-[#b4ff39] text-black font-semibold text-sm rounded-xl shadow-md shadow-[#b4ff39]/20 hover:bg-[#a3eb2f] transition">
                        Go Shopping
                    </a>
                </div>
            <% } %>
        </div>

        <div class="w-full md:w-[35%] bg-[#111111] p-6 rounded-2xl border border-white/5 shadow-sm sticky top-24">
            <h3 class="text-lg font-bold text-white pb-4 border-b border-white/5">Price Breakdown</h3>
            
            <div class="mt-5 space-y-3 text-sm font-medium text-gray-400">
                <div class="flex justify-between">
                    <span>Total MRP</span>
                    <span class="text-white">Rs. <%= totalMRP.toLocaleString() %></span>
                </div>
                <div class="flex justify-between">
                    <span>Discount on MRP</span>
                    <span class="text-[#b4ff39]">- Rs. <%= totalDiscount.toLocaleString() %></span>
                </div>
                <div class="flex justify-between">
                    <span>Platform Fee</span>
                    <span class="text-white">Rs. <%= platformFee %></span>
                </div>
                <div class="flex justify-between">
                    <span>Shipping Fee</span>
                    <span class="text-[#b4ff39] font-semibold">FREE</span>
                </div>
            </div>

            <div class="w-full h-[1px] bg-white/5 my-5"></div>

            <div class="flex justify-between items-center mb-6">
                <h3 class="text-base font-bold text-white">Total Amount</h3>
                <% let grandTotal = (totalMRP - totalDiscount) + platformFee; %>
                <h3 class="font-bold text-xl text-[#b4ff39]">Rs. <%= grandTotal.toLocaleString() %></h3>
            </div>

          <% if (products.length > 0) { %>
    <form action="/cart/checkout" method="POST">
        <button type="submit" class="w-full py-3.5 bg-[#b4ff39] hover:bg-[#a3eb2f] active:scale-[0.99] transition text-black font-semibold rounded-xl text-sm shadow-lg shadow-[#b4ff39]/20 tracking-wide">
            Proceed to Checkout
        </button>
    </form>
<% } else { %>
    <button disabled class="w-full py-3.5 bg-white/5 text-gray-500 font-semibold rounded-xl text-sm cursor-not-allowed text-center border border-white/5">
        Cart is Empty
    </button>
<% } %>
        </div>

    </div>

<script>
    function updateCart(productId, action) {
        window.location.href = `/cart/${action}/${productId}`;
    }
</script>
</body>
</html>
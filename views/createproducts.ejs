<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Product — Stowe Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-[#0a0a0a] text-gray-200 antialiased min-h-screen">

<%- include('partials/flash') %>

<!-- Admin Top Bar -->
<header class="w-full h-16 bg-[#0a0a0a]/80 border-b border-white/5 flex items-center px-8 justify-between sticky top-0 z-40 backdrop-blur-md">
    <div class="flex items-center space-x-3">
        <div class="w-8 h-8 bg-[#b4ff39] rounded-lg flex items-center justify-center font-bold text-black text-base shadow-sm shadow-[#b4ff39]/30">S</div>
        <span class="font-bold text-white tracking-tight text-lg">Stowe Admin</span>
    </div>
    <div class="flex items-center space-x-4">
        <a href="/owners" class="text-xs font-bold uppercase tracking-wider text-gray-400 hover:text-white border border-white/5 bg-white/5 rounded-lg px-3 py-1.5 transition">
            Dashboard
        </a>
        <a href="/products" class="text-xs font-bold uppercase tracking-wider text-gray-400 hover:text-white border border-white/5 bg-white/5 rounded-lg px-3 py-1.5 transition">
            View Store
        </a>
    </div>
</header>

<div class="max-w-3xl mx-auto px-6 py-12">

    <div class="mb-8">
        <h2 class="text-2xl font-bold tracking-tight text-white">Create New Product</h2>
        <p class="text-gray-500 text-sm mt-1">Fill out the details below to add a new product to your store.</p>
    </div>

    <form autocomplete="off" action="/owners/creatingproduct" method="post" enctype="multipart/form-data" class="space-y-8">

        <!-- Product Specifications -->
        <div class="bg-[#111111] rounded-2xl border border-white/5 p-6 space-y-5">
            <div class="flex items-center space-x-2 mb-2">
                <span class="w-1.5 h-4 bg-[#b4ff39] rounded-full"></span>
                <h3 class="text-base font-bold text-white">Product Details</h3>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Product Image</label>
                <label class="relative flex flex-col items-center justify-center border-2 border-dashed border-white/10 bg-[#1a1a1a] rounded-2xl p-6 cursor-pointer hover:border-[#b4ff39]/40 transition group">
                    <div class="text-center">
                        <i class="ri-image-add-line text-3xl text-gray-500 group-hover:text-[#b4ff39] transition"></i>
                        <p class="text-sm font-semibold text-gray-300 mt-2">Click to upload image</p>
                        <p class="text-xs text-gray-500 mt-0.5">PNG, JPG up to 5MB</p>
                    </div>
                    <input name="image" type="file" accept="image/*" required class="hidden">
                </label>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Name</label>
                    <input name="name" type="text" placeholder="e.g. Classic Travel Backpack" required
                        class="w-full bg-[#1a1a1a] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-[#b4ff39] transition">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Price (Rs)</label>
                    <input name="price" type="number" placeholder="0" required min="0" step="1"
                        class="w-full bg-[#1a1a1a] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-[#b4ff39] transition">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Discount (Rs)</label>
                    <input name="discount" type="number" placeholder="0" min="0" step="1"
                        class="w-full bg-[#1a1a1a] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-[#b4ff39] transition">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Stock Quantity</label>
                    <input name="stock" type="number" placeholder="10" min="0" required
                        class="w-full bg-[#1a1a1a] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-[#b4ff39] transition">
                </div>
            </div>
        </div>

        <!-- Design Settings -->
        <div class="bg-[#111111] rounded-2xl border border-white/5 p-6 space-y-5">
            <div class="flex items-center space-x-2 mb-2">
                <span class="w-1.5 h-4 bg-violet-500 rounded-full"></span>
                <h3 class="text-base font-bold text-white">Display Colors</h3>
                <span class="text-xs text-gray-500">(controls product card appearance)</span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Background</label>
                    <div class="flex items-center gap-2 bg-[#1a1a1a] border border-white/10 rounded-xl px-3 py-2">
                        <input name="bgcolor" type="color" value="#1a1a1a"
                            class="w-9 h-9 rounded-lg cursor-pointer bg-transparent border border-white/10">
                        <span class="text-xs text-gray-400">Image stage</span>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Panel</label>
                    <div class="flex items-center gap-2 bg-[#1a1a1a] border border-white/10 rounded-xl px-3 py-2">
                        <input name="panelcolor" type="color" value="#111111"
                            class="w-9 h-9 rounded-lg cursor-pointer bg-transparent border border-white/10">
                        <span class="text-xs text-gray-400">Info panel</span>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Text</label>
                    <div class="flex items-center gap-2 bg-[#1a1a1a] border border-white/10 rounded-xl px-3 py-2">
                        <input name="textcolor" type="color" value="#e5e7eb"
                            class="w-9 h-9 rounded-lg cursor-pointer bg-transparent border border-white/10">
                        <span class="text-xs text-gray-400">Name & price</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex justify-end">
            <button type="submit" class="px-6 py-3 rounded-xl bg-[#b4ff39] hover:bg-[#a3eb2f] text-black font-semibold text-sm shadow-lg shadow-[#b4ff39]/20 active:scale-[0.98] transition duration-150">
                Publish Product
            </button>
        </div>
    </form>
</div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Owner Login — Stowe Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0a0a0a] min-h-screen flex items-center justify-center p-4 font-sans text-white">

<%- include('partials/flash') %>

<div class="w-full max-w-sm bg-[#111111] rounded-2xl shadow-2xl shadow-black border border-white/5 p-8">
    <div class="text-center mb-8">
        <div class="w-10 h-10 bg-[#b4ff39] rounded-lg flex items-center justify-center font-bold text-black text-lg mx-auto mb-3">S</div>
        <h2 class="text-xl font-bold text-white">Owner Login</h2>
        <p class="text-sm text-gray-400 mt-1">Stowe Admin Dashboard</p>
    </div>

    <form action="/owners/login" method="post" class="space-y-4">
        <input type="email" placeholder="Email Address" name="email" required
            class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-[#b4ff39] focus:border-[#b4ff39] outline-none transition-all">
        <input type="password" placeholder="Password" name="password" required
            class="w-full px-4 py-2.5 bg-[#1a1a1a] border border-white/10 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-[#b4ff39] focus:border-[#b4ff39] outline-none transition-all">

        <button type="submit"
            class="w-full bg-[#b4ff39] hover:bg-[#a3eb2f] text-black font-semibold py-2.5 rounded-lg text-sm transition-colors">
            Login
        </button>
    </form>
</div>

</body>
</html>